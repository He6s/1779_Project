# Copy this to .env.doks and load it before running scripts/deploy_doks.ps1
# Example PowerShell loading command:
# Get-Content .env.doks | ForEach-Object { if ($_ -match '^[^#].+=') { $name, $value = $_ -split '=', 2; [Environment]::SetEnvironmentVariable($name, $value) } }

# Required by deploy_doks.ps1
POSTGRES_DB=settleup
POSTGRES_USER=settleup_user
POSTGRES_PASSWORD=change_me
JWT_SECRET=change_this_in_production

# Optional / email
EMAIL_ENABLED=false
EMAIL_FROM=no-reply@settleup.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Script parameters (not read automatically by script)
# DOKS_CLUSTER_NAME=<your-cluster-name>
# REGISTRY_PREFIX=registry.digitalocean.com/<your-registry-name>
